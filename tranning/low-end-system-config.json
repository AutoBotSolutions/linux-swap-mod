{
  "config_name": "Low-End System Optimization",
  "description": "Configuration for low-end systems with limited RAM and CPU",
  "target_system": "Low-End Desktops and Laptops",
  "optimization_level": "conservative",
  "priority_tiers": {
    "ai": {
      "nice_value": -5,
      "ionice_class": 2,
      "ionice_priority": 0,
      "process_patterns": [
        "python",
        "tensor",
        "torch"
      ],
      "memory_priority": "high",
      "cpu_affinity": "balanced"
    },
    "ide": {
      "nice_value": -3,
      "ionice_class": 2,
      "ionice_priority": 0,
      "process_patterns": [
        "code",
        "vim",
        "nano"
      ],
      "memory_priority": "medium",
      "cpu_affinity": "balanced"
    },
    "interactive": {
      "nice_value": 0,
      "ionice_class": 2,
      "ionice_priority": 4,
      "process_patterns": [
        "firefox",
        "chrome",
        "terminal"
      ],
      "memory_priority": "normal",
      "cpu_affinity": "balanced"
    },
    "normal": {
      "nice_value": 15,
      "ionice_class": 2,
      "ionice_priority": 7,
      "process_patterns": [
        "systemd",
        "dbus"
      ],
      "memory_priority": "low",
      "cpu_affinity": "powersave"
    },
    "background": {
      "nice_value": 19,
      "ionice_class": 3,
      "ionice_priority": 7,
      "process_patterns": [
        "updatedb",
        "backup"
      ],
      "memory_priority": "minimal",
      "cpu_affinity": "powersave"
    }
  },
  "kernel_parameters": {
    "vm.swappiness": 1,
    "vm.vfs_cache_pressure": 75,
    "vm.dirty_ratio": 5,
    "vm.dirty_background_ratio": 2,
    "vm.min_free_kbytes": 131072
  },
  "swap_settings": {
    "enable_swap": true,
    "swap_priority": "memory_first",
    "swap_threshold": 70,
    "aggressive_swap": true
  },
  "monitoring": {
    "check_interval": 5,
    "memory_threshold": 85,
    "cpu_threshold": 90,
    "swap_threshold": 60,
    "auto_adjust": true
  }
}
